# Auth Service Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/quantummint
MONGODB_DB_NAME=quantummint

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=quantummint-auth

# Service Communication
SERVICE_KEY=default_service_key
API_GATEWAY_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
CSRF_SECRET=your_csrf_secret_here

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@quantummint.com
FROM_NAME=QuantumMint

# Email Templates
EMAIL_VERIFICATION_SUBJECT=Verify your QuantumMint account
PASSWORD_RESET_SUBJECT=Reset your QuantumMint password

# Two-Factor Authentication
TFA_ISSUER=QuantumMint
TFA_ALGORITHM=SHA1
TFA_DIGITS=6
TFA_PERIOD=30

# Password Reset
PASSWORD_RESET_EXPIRES_IN=10m
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15m
PASSWORD_MIN_LENGTH=8

# Logging
LOG_LEVEL=info
LOG_FILE=logs/auth-service.log

# Redis Configuration (if using for session storage)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Monitoring
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# File Upload (for profile pictures, etc.)
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Phone Verification (if using SMS)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890





