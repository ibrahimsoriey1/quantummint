# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/quantummint_auth
MONGODB_URI_TEST=mongodb://localhost:27017/quantummint_auth_test

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Two-Factor Authentication
TWO_FACTOR_ISSUER=QuantumMint
TWO_FACTOR_ALGORITHM=SHA1
TWO_FACTOR_DIGITS=6
TWO_FACTOR_PERIOD=30

# Security Configuration
BCRYPT_ROUNDS=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_TIME=7200000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=auth-service.log

# CORS Configuration
CORS_ORIGIN=http://localhost:3006
CORS_CREDENTIALS=true

# API Configuration
API_VERSION=v1
API_PREFIX=/api/v1

# External Services
PAYMENT_SERVICE_URL=http://localhost:3004
KYC_SERVICE_URL=http://localhost:3005
MONEY_GENERATION_SERVICE_URL=http://localhost:3002
TRANSACTION_SERVICE_URL=http://localhost:3003
