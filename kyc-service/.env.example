# Server Configuration
PORT=3005
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/quantummint_kyc

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=quantummint-kyc-documents

# Service Keys
SERVICE_KEY=your_service_key_for_internal_communication

# Verification Limits
TIER1_VERIFICATION_EXPIRY_DAYS=90
TIER2_VERIFICATION_EXPIRY_DAYS=180
TIER3_VERIFICATION_EXPIRY_DAYS=365

# Document Upload Limits
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf