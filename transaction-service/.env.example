# Server Configuration
PORT=3003
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/quantummint_transactions

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_EXCHANGE=quantummint_exchange
RABBITMQ_QUEUE=transaction_queue

# Service Keys
SERVICE_KEY=your_service_key_for_internal_communication

# Money Generation Service
MONEY_GENERATION_SERVICE_URL=http://localhost:3002/api/generation

# Payment Integration Service
PAYMENT_INTEGRATION_SERVICE_URL=http://localhost:3004/api/payments