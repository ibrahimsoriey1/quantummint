# Server Configuration
PORT=3002
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/quantummint_generation

# JWT Configuration
JWT_SECRET=your_jwt_secret_key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_EXCHANGE=quantummint_exchange
RABBITMQ_QUEUE=generation_queue

# Generation Limits
STANDARD_DAILY_LIMIT=1000
ACCELERATED_DAILY_LIMIT=2000
PREMIUM_DAILY_LIMIT=5000

# Generation Rates (units per minute)
STANDARD_RATE=10
ACCELERATED_RATE=20
PREMIUM_RATE=50

# KYC Service
KYC_SERVICE_URL=http://localhost:3005/api/kyc

# Transaction Service
TRANSACTION_SERVICE_URL=http://localhost:3003/api/transactions