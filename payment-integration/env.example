# Payment Integration Service Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3004
HOST=localhost

# Database Configuration
MONGODB_URI_DEV=mongodb://localhost:27017/quantum_mint_payments_dev
MONGODB_URI_TEST=mongodb://localhost:27017/quantum_mint_payments_test
MONGODB_URI_PROD=mongodb://localhost:27017/quantum_mint_payments

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=2

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
TRANSACTION_SERVICE_URL=http://localhost:3003
KYC_SERVICE_URL=http://localhost:3005
FRONTEND_URL=http://localhost:3006

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2023-10-16

# Orange Money Configuration
ORANGE_MONEY_MERCHANT_ID=your_merchant_id_here
ORANGE_MONEY_CLIENT_ID=your_client_id_here
ORANGE_MONEY_CLIENT_SECRET=your_client_secret_here
ORANGE_MONEY_ENVIRONMENT=sandbox
ORANGE_MONEY_API_URL=https://api.orange.com
ORANGE_MONEY_WEBHOOK_SECRET=your_webhook_secret_here

# AfriMoney Configuration
AFRIMONEY_MERCHANT_ID=your_merchant_id_here
AFRIMONEY_API_KEY=your_api_key_here
AFRIMONEY_SECRET_KEY=your_secret_key_here
AFRIMONEY_ENVIRONMENT=sandbox
AFRIMONEY_API_URL=https://api.afrimoney.com
AFRIMONEY_WEBHOOK_SECRET=your_webhook_secret_here

# Payment Configuration
PAYMENT_TIMEOUT_MINUTES=30
MAX_PAYMENT_AMOUNT=1000000.00
MIN_PAYMENT_AMOUNT=1.00
SUPPORTED_CURRENCIES=USD,EUR,GBP,XOF,XAF
DEFAULT_CURRENCY=USD
EXCHANGE_RATE_UPDATE_INTERVAL=3600000

# Security Configuration
CORS_ORIGIN=http://localhost:3006
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_KEY_HEADER=X-API-Key
API_KEY=your-api-key-here
WEBHOOK_IP_WHITELIST=127.0.0.1,::1

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14

# Monitoring Configuration
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
PROMETHEUS_PORT=9091

# Notification Configuration
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_API_KEY=
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# Compliance Configuration
COMPLIANCE_CHECK_ENABLED=true
AML_CHECK_ENABLED=true
KYC_REQUIRED_FOR_PAYMENTS=true
MIN_KYC_LEVEL_REQUIRED=verified

# Performance Configuration
CACHE_TTL_SECONDS=300
BATCH_PROCESSING_ENABLED=true
ASYNC_PROCESSING_ENABLED=true
PAYMENT_QUEUE_SIZE=1000

# File Upload Configuration
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=./uploads
TEMP_PATH=./temp

# Exchange Rate Configuration
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
EXCHANGE_RATE_FALLBACK_RATES={"USD":1,"EUR":0.85,"GBP":0.73,"XOF":550,"XAF":550}

# Webhook Configuration
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_MS=5000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature

# Fraud Detection Configuration
FRAUD_DETECTION_ENABLED=true
SUSPICIOUS_AMOUNT_THRESHOLD=10000
SUSPICIOUS_FREQUENCY_THRESHOLD=10
SUSPICIOUS_TIME_WINDOW_MINUTES=60

# Settlement Configuration
SETTLEMENT_BATCH_SIZE=100
SETTLEMENT_INTERVAL_HOURS=24
SETTLEMENT_CURRENCIES=USD,EUR,GBP
SETTLEMENT_THRESHOLD_AMOUNT=1000
