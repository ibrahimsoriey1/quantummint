# Frontend Environment Variables

# API Configuration
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_API_BASE_URL=http://localhost:3000

# Environment
REACT_APP_NODE_ENV=development

# Authentication
REACT_APP_JWT_STORAGE_KEY=quantummint_token
REACT_APP_REFRESH_TOKEN_KEY=quantummint_refresh_token

# Feature Flags
REACT_APP_ENABLE_2FA=true
REACT_APP_ENABLE_KYC=true
REACT_APP_ENABLE_ANALYTICS=false

# External Services
REACT_APP_GOOGLE_ANALYTICS_ID=
REACT_APP_SENTRY_DSN=

# App Configuration
REACT_APP_APP_NAME=QuantumMint
REACT_APP_APP_VERSION=1.0.0
REACT_APP_SUPPORT_EMAIL=support@quantummint.com

# Payment Providers
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
REACT_APP_PAYPAL_CLIENT_ID=your_paypal_client_id

# Social Login (if implemented)
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_FACEBOOK_APP_ID=

# WebSocket Configuration (if using real-time features)
REACT_APP_WS_URL=ws://localhost:3000/ws

# File Upload
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Theme Configuration
REACT_APP_DEFAULT_THEME=light
REACT_APP_ENABLE_DARK_MODE=true

# Development Tools
REACT_APP_ENABLE_DEV_TOOLS=true
REACT_APP_LOG_LEVEL=debug

# Security
REACT_APP_ENABLE_CSRF=true
REACT_APP_SESSION_TIMEOUT=3600000

# Internationalization
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,es,fr

# Performance
REACT_APP_ENABLE_SERVICE_WORKER=false
REACT_APP_CACHE_VERSION=1.0.0

# Monitoring
REACT_APP_ENABLE_ERROR_REPORTING=false
REACT_APP_ERROR_REPORTING_URL=

# Build Configuration
GENERATE_SOURCEMAP=false
REACT_APP_BUILD_TIMESTAMP=





